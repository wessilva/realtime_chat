<div class="min-h-[calc(100vh-65px)] flex items-center justify-center bg-gray-900 px-4">
  <div class="w-full max-w-md bg-gray-800 rounded-lg shadow-lg p-8">

    <!-- Header -->
    <div class="flex flex-col items-center mb-8">
      <i class="fa-solid fa-shield-cat fa-3x mb-3" style="color: #a66cfe"></i>
      <h2 class="text-2xl font-bold text-white">Bem-vindo de volta</h2>
      <p class="text-gray-400 text-sm mt-1">Entre na sua conta para continuar</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <!-- Flash errors -->
      <% if resource.errors.any? %>
        <div class="bg-red-500 bg-opacity-20 border border-red-500 text-red-400 rounded-lg px-4 py-3 mb-6 text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Email -->
      <div class="mb-5">
        <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "seu@email.com",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
      </div>

      <!-- Password -->
      <div class="mb-5">
        <div class="flex justify-between items-center mb-2">
          <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-300" %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Esqueceu a senha?", new_password_path(resource_name),
                  class: "text-xs text-violet-400 hover:underline" %>
          <% end %>
        </div>
        <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
      </div>

      <!-- Remember me -->
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-6">
          <%= f.check_box :remember_me,
                class: "w-4 h-4 accent-violet-500 cursor-pointer" %>
          <%= f.label :remember_me, "Lembrar de mim",
                class: "ml-2 text-sm text-gray-400 cursor-pointer" %>
        </div>
      <% end %>

      <!-- Submit -->
      <%= f.submit "Entrar",
            class: "w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors cursor-pointer" %>
    <% end %>

    <!-- Links -->
    <% if devise_mapping.registerable? %>
      <p class="text-center text-sm text-gray-400 mt-6">
        Não tem uma conta?
        <%= link_to "Criar conta", new_registration_path(resource_name),
              class: "text-violet-400 font-medium hover:underline" %>
      </p>
    <% end %>

  </div>
</div>
