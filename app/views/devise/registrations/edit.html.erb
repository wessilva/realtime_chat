<div class="min-h-[calc(100vh-65px)] flex items-center justify-center bg-gray-900 px-4 py-10">
  <div class="w-full max-w-md bg-gray-800 rounded-lg shadow-lg p-8">

    <!-- Header -->
    <div class="flex flex-col items-center mb-8">
      <% if current_user&.avatar.present? %>
        <div id="user_avatar_<%= current_user.id %>" class="mb-3 flex flex-col items-center gap-3">
          <%= image_tag current_user.avatar, class: "w-20 h-20 rounded-full object-cover border-2 border-violet-500" %>
          <%= link_to "Remover foto", user_avatar_path(current_user),
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                class: "text-xs text-red-400 hover:underline" %>
        </div>
      <% else %>
        <div class="w-20 h-20 rounded-full bg-violet-600 flex items-center justify-center mb-3">
          <span class="text-white text-2xl font-bold">
            <%= current_user.name.to_s[0]&.upcase || current_user.email[0].upcase %>
          </span>
        </div>
      <% end %>
      <h2 class="text-2xl font-bold text-white">Editar Perfil</h2>
      <p class="text-gray-400 text-sm mt-1">Atualize suas informações</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

      <!-- Erros -->
      <% if resource.errors.any? %>
        <div class="bg-red-500 bg-opacity-20 border border-red-500 text-red-400 rounded-lg px-4 py-3 mb-6 text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Avatar -->
      <div class="mb-5">
        <%= f.label :avatar, "Foto de perfil", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.file_field :avatar,
              accept: "image/*",
              class: "w-full text-sm text-gray-400 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-violet-600 file:text-white file:cursor-pointer hover:file:bg-violet-500 bg-gray-700 rounded-lg border border-gray-600 cursor-pointer" %>
      </div>

      <!-- Email -->
      <div class="mb-5">
        <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-xs text-yellow-400 mt-1">Aguardando confirmação para: <%= resource.unconfirmed_email %></p>
        <% end %>
      </div>

      <!-- Nova senha -->
      <div class="mb-5">
        <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.password_field :password,
              autocomplete: "new-password",
              placeholder: "Deixe em branco para não alterar",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mt-1">Mínimo de <%= @minimum_password_length %> caracteres</p>
        <% end %>
      </div>

      <!-- Confirmação de senha -->
      <div class="mb-5">
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
      </div>

      <!-- Senha atual -->
      <div class="mb-6">
        <%= f.label :current_password, "Senha atual", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= f.password_field :current_password,
              autocomplete: "current-password",
              placeholder: "Necessária para confirmar as alterações",
              class: "w-full bg-gray-700 text-white placeholder-gray-500 border border-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
      </div>

      <!-- Submit -->
      <%= f.submit "Salvar alterações",
            class: "w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors cursor-pointer" %>
    <% end %>

    <!-- Cancelar conta -->
    <div class="mt-8 pt-6 border-t border-gray-700">
      <p class="text-sm text-gray-500 mb-3 text-center">Zona de perigo</p>
      <%= button_to "Cancelar minha conta", registration_path(resource_name),
            data: { turbo_confirm: "Tem certeza? Esta ação não pode ser desfeita." },
            method: :delete,
            class: "w-full bg-transparent border border-red-600 text-red-400 hover:bg-red-600 hover:text-white font-medium py-2.5 rounded-lg text-sm transition-colors cursor-pointer" %>
    </div>

  </div>
</div>
