<style>
  <%= ".cUser_msgAlign_#{current_user&.id}" %> { display: flex; justify-content: flex-end }
  <%= ".cUser_msg_#{current_user&.id}" %> { background-color: rgb(0, 0, 0) !important; padding: 10px; }
  <%= ".cUser_delButton_#{current_user&.id}" %> { display: block; }
</style>

<%= turbo_stream_from @current_room %>
<%= turbo_stream_from "user_#{current_user.id}_channel" %>

<%= turbo_stream_from "groups" %>
<%= turbo_stream_from "users" %>
<%= turbo_stream_from "user_mode" %>
<%= turbo_stream_from "user_mode_channel" %>
<%= turbo_stream_from "user_notification_#{current_user.id}_channel" %>

<div
  class="flex flex-col md:flex-row md:space-x-0 overflow-y-auto"
  style="overflow-y: hidden;"
>
  <div
    class="
      bg-gray-800 py-0 px-4 w-1/3 overflow-y-auto sm:h-[calc(100vh-65px)]
      h-[calc(75vh-65px)]
    "
    style="white-space: nowrap; text-overflow: ellipsis;"
  >
    <div class="py-2">
      <div class="flex flex-col md:flex-row justify-between items-center py-2">
        <div class="text-left">
          <h2 class="font-bold uppercase text-gray-200">
            Hello, <%= current_user.name %>
          </h2>
        </div>

        <div class="text-right">
          <%# = render partial: 'layouts/submenu/three_points' %>
        </div>
      </div>

      <%= render "search/form_search" %>
    </div>

    <div class="h-auto md:h-[calc(100vh-250px)] overflow-y-auto">
      <div id="found-results"></div>
      <h2 class="pt-2 text-gray-400 text-xs tracking-widest">GROUPS</h2>
      <div id="groups"><%= render @groups %></div>
      <h2 class="pt-2 text-gray-400 text-xs tracking-widest">USERS</h2>
      <div id="users"><%= render @users %></div>
    </div>
  </div>

  <!-- RIGHT COLUMN -->
<div
  class="
    bg-gray-100 p-4 pb-2 md:col-span-1 md:w-2/3 overflow-y-auto
    sm:h-[calc(100vh-65px)] h-[calc(75vh-65px)]
  "
>
  <div>
    <div class="flex justify-between">
      <div class="text-left">
        <h2 class="font-bold">
          Write a message to <span class="uppercase">"<%= @user&.name %>"</span>
        </h2>
      </div>

      <div>
        <%= render partial: 'add_or_remove_contact' %>
      </div>
    </div>

    <!-- CHAT ROOM -->
    <div
      data-controller="chat"
      class="h-[calc(100vh-280px)] ssm:h-75 overflow-y-auto"
    >
      <div data-controller="notifications-update">
        <div
          id="messages"
          data-notifications-update-target="messageArea"
          tabindex="0"
        >
          <% @messages.each do |message| %>
          <%= render partial: "messages/message", locals: { message: message, delButton: message.user == current_user} %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- RENDER NEW MESSAGE FORM -->
  <div class="py-2">
    <%= render 'messages/form_new_message' %>
  </div>
</div>
</div>
