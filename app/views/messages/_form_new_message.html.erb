<div class="flex justify-center">
  <% if @current_room || @current_group %>
    <%= form_with(model: [@current_room || @current_group, @message], class: "contents") do |form| %>
      <div class="flex bg-red-700 rounded-full py-2 px-2 pr-3 w-full md:w-7/12">
        <!-- icon paperclip attachments -->
        <div class="my-2">
          <label for="set_attachments" class="cursor-pointer">
            <i
              class="
                fa-solid fa-paperclip h-8 w-8 text-white-100 px-2
                hover:text-gray-500
              "
            ></i>
          </label>
        </div>

        <!-- Message Input Field -->
        <div class="w-full pr-2">
          <%= form.text_field :body, autocomplete: "off",
                class: "block shadow rounded-full border border-gray-200 outline-none px-3 mt-1 w-full" %>
        </div>

        <!-- Send Button -->
        <div class="actions">
          <%= button_tag(type: 'submit',  class: 'rounded-full h-12 w-12 items-center justify-center bg-blue-600 text-white inline-block font-medium cursor-pointer bg-gray-800 hover:bg-gray-600 focus:outline-none focus:ring-4 focus:ring-gray-300 font-medium rounded-full dark:bg-gray-800 dark:hover:bg-gray-700 dark:focus:ring-gray-700 dark:border-gray-700 flex') do %>
            <i class="fa fa-paper-plane h-6 w-6"></i>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
