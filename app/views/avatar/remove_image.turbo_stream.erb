<%# = We use here case statement between Users Avatars and Groups Avatars %>
<%= turbo_stream.update instance do %>
  <% case partial %>
  <% when "groups/group" %>
    <%= render partial: partial, locals: { instance:, group: @group } %>
  <% when "users/user" %>
    <%= render partial: partial, locals: { instance:, user: @user } %>
  <% end %>
<% end %>

