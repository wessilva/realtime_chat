<div class="min-h-[calc(100vh-65px)] flex items-center justify-center bg-gray-900 px-4">
  <div class="w-full max-w-md bg-gray-800 rounded-lg shadow-lg p-8 text-center">

    <!-- Ícone -->
    <i class="fa-solid fa-shield-cat fa-4x mb-5" style="color: #a66cfe"></i>

    <!-- Título -->
    <h1 class="text-3xl font-bold text-white mb-2">Real-time Chat</h1>
    <p class="text-gray-400 text-sm mb-8">Converse em tempo real com seus contatos</p>

    <% if current_user %>
      <!-- Usuário logado -->
      <p class="text-gray-300 text-sm mb-6">
        Olá, <span class="text-violet-400 font-semibold"><%= current_user.name.presence || current_user.email %></span>!
      </p>

      <%= link_to user_contacts_path(current_user),
            class: "block w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors mb-3" do %>
        <i class="fa-solid fa-comments mr-2"></i>Ir para o Chat
      <% end %>

      <div class="flex gap-3">
        <%= link_to "Editar Perfil", edit_user_registration_path,
              class: "flex-1 bg-gray-700 hover:bg-gray-600 text-gray-300 font-medium py-2.5 rounded-lg text-sm transition-colors" %>
        <%= button_to "Logout", destroy_user_session_path, method: :delete,
              class: "flex-1 bg-gray-700 hover:bg-red-600 text-gray-300 hover:text-white font-medium py-2.5 rounded-lg text-sm transition-colors cursor-pointer" %>
      </div>

    <% else %>
      <!-- Usuário deslogado -->
      <%= link_to new_user_session_path,
            class: "block w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors mb-3" do %>
        <i class="fa-solid fa-right-to-bracket mr-2"></i>Entrar
      <% end %>

      <%= link_to new_user_registration_path,
            class: "block w-full bg-gray-700 hover:bg-gray-600 text-gray-300 font-medium py-2.5 rounded-lg text-sm transition-colors" do %>
        <i class="fa-solid fa-user-plus mr-2"></i>Criar conta
      <% end %>
    <% end %>

  </div>
</div>
