<% if flash.present? %>
  <div
    id="flash_message"
    class="
      flash-popup fixed top-5 left-1/2 transform -translate-x-1/2 z-50
      max-w-sm w-full bg-green-500 text-white rounded-lg shadow-lg
    "
  >
    <% flash.each do |type, msg| %>
      <div
        data-controller="alert"
        data-alert-target="hideable"
        class="<%= "alert-#{type}" %> text-white px-4 py-3 rounded relative"
        role="alert"
      >
        <div>
          <div class="p-2">
            <strong class="font-bold text-white"><%= msg %></strong>
          </div>

          <%# Close button %>
          <div data-action="click->alert#hideMe">
            <span class="absolute top-0 bottom-0 right-0 px-4 pt-5">
              <svg
                class="fill-current h-6 w-6 text-white"
                role="button"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
              >
                <title>Close</title>

                <path
                  d="M14.348 14.849a1.2 1.2 0 0 1-1.697 0L10 11.819l-2.651 3.029a1.2 1.2 0 1 1-1.697-1.697l2.758-3.15-2.759-3.152a1.2 1.2 0 1 1 1.697-1.697L10 8.183l2.651-3.031a1.2 1.2 0 1 1 1.697 1.697l-2.758 3.152 2.758 3.15a1.2 1.2 0 0 1 0 1.698z"
                />
              </svg>
            </span>
          </div>

          <%# end Close button %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
